# =============================================
# JARVIS CLAW v1.0.0 — Environment Variables
# =============================================

# --- LLM Providers (at least 1 required) ---
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
MISTRAL_API_KEY=your_mistral_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Web Search (Knowledge Cutoff Bypass) ---
TAVILY_API_KEY=your_tavily_key_here   # Free: https://tavily.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token  # Get from @BotFather → /newbot
TELEGRAM_WEBHOOK_SECRET=your_random_secret_32_chars  # For webhook mode

# --- ClawHub ---
CLAWHUB_TOKEN=your_clawhub_token  # Get from https://clawhub.io → Settings

# --- Agent Config ---
AGENT_NAME=Jarvis Claw
PRIMARY_LLM=gemini                # gemini | groq | mistral | openrouter
MAX_TOKENS=8192
TEMPERATURE=0.7
AUTO_WEB_SEARCH=true              # Auto-search for current events
WEB_SEARCH_CACHE_TTL=300          # Cache web results for 5 min (seconds)
RATE_LIMIT_PER_MIN=10             # Max requests per chat per minute

# --- Persistence ---
MEMORY_DB_PATH=/data/.openclaw/memory.db
CONFIG_PATH=/data/.openclaw/config.json
